{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "baseUrl": "src",
    "paths": {
      "api/*": ["api/*"],
      "config/*": ["config/*"],
      "utils/*": ["utils/*"],
      "middlewares/*": ["middlewares/*"],
      "metadata/*": ["metadata/*"],
      "common/*": ["common/*"],
      "gateways/*": ["gateways/*"],
      "tasks/*": ["tasks/*"],
      "lib/*": ["lib/*"],
      "decorators": ["decorators/index.js"],
      "exceptions": ["exceptions/index.js"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/migrations",
    "src/seeds",
    "src/scripts"
  ]
}
